# Copy this file to .env and adjust values.
# .env is gitignored — never commit real keys.
# Restart `node proxy.js` after any change.

# ── Proxy ──────────────────────────────────────────────────────
PROXY_PORT=8012

# ── Tickers to track (comma-separated) ────────────────────────
# Add any US stock ticker or crypto symbol supported by Yahoo Finance.
# Crypto tickers should also appear in YAHOO_SYMBOLS and CRYPTO_TICKERS.
TICKERS=NVDA,TSLA,AAPL,MSFT,GOOGL,AMZN,AVGO,INTC,ONDS,BTC,ETH,SOL,SPY,GLD,XOM,CVX,PFE,F,OWL

# ── Sector per ticker (TICKER:sector pairs, comma-separated) ──
# Used for the sector filter dropdown in the UI.
# Available sectors: tech, crypto, macro, energy
TICKER_SECTORS=NVDA:tech,TSLA:tech,AAPL:tech,MSFT:tech,GOOGL:tech,AMZN:tech,AVGO:tech,INTC:tech,ONDS:tech,BTC:crypto,ETH:crypto,SOL:crypto,SPY:macro,GLD:macro,PFE:macro,F:macro,OWL:macro,XOM:energy,CVX:energy

# ── Polymarket search keywords (TICKER:keyword, comma-separated)
# Polymarket markets use plain-language titles, not ticker symbols.
# Map each ticker to a keyword that matches relevant open markets.
POLYMARKET_KEYWORDS=NVDA:nvidia,TSLA:tesla,AAPL:apple,MSFT:microsoft,GOOGL:google,AMZN:amazon,AVGO:broadcom,INTC:intel,ONDS:ondas,BTC:bitcoin,ETH:ethereum,SOL:solana,SPY:fed rate,GLD:gold,XOM:oil,CVX:chevron,PFE:pfizer,F:ford,OWL:blue owl

# ── Yahoo Finance symbol overrides (TICKER:YAHOO_SYMBOL) ──────
# Crypto and some ETFs use a different symbol on Yahoo Finance.
# Stocks (NVDA, TSLA, etc.) do not need an entry here.
YAHOO_SYMBOLS=BTC:BTC-USD,ETH:ETH-USD,SOL:SOL-USD

# ── Crypto tickers (comma-separated) ─────────────────────────
# Controls the MarketWatch URL pattern (/investing/cryptocurrency/...)
# and the -USD suffix handling for Yahoo Finance chart fetches.
CRYPTO_TICKERS=BTC,ETH,SOL

# ── Optional API keys ─────────────────────────────────────────
# Not required for current data sources (Polymarket public API + Yahoo Finance).
# STOCK_API_KEY=your_key_here
# POLYMARKET_API_KEY=your_key_here
